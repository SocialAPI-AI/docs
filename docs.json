{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SocAPI",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "openapi": "api-reference/openapi.yaml",
  "llms": {
    "enabled": true
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/authentication",
              "guides/pagination",
              "guides/rate-limits",
              "guides/platforms"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Accounts",
            "pages": [
              "api-reference/accounts/list-accounts",
              "api-reference/accounts/connect-account"
            ]
          },
          {
            "group": "Comments",
            "pages": [
              "api-reference/comments/list-comments",
              "api-reference/comments/list-replies",
              "api-reference/comments/reply",
              "api-reference/comments/moderate",
              "api-reference/comments/toggle"
            ]
          },
          {
            "group": "Reviews",
            "pages": ["api-reference/reviews/list-reviews"]
          },
          {
            "group": "Direct Messages",
            "pages": [
              "api-reference/dms/list-dms",
              "api-reference/dms/lookup-thread",
              "api-reference/dms/send-dm"
            ]
          },
          {
            "group": "Mentions",
            "pages": ["api-reference/mentions/list-mentions"]
          },
          {
            "group": "Usage",
            "pages": [
              "api-reference/usage/get-usage",
              "api-reference/usage/get-limits"
            ]
          },
          {
            "group": "Search",
            "pages": ["api-reference/search/search"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/SocAPI-AI",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@socapi.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://socapi.ai"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/SocAPI-AI"
    }
  }
}
